{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/Auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "user-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ]
    },
    {
      "DownstreamPathTemplate": "/api/Urls/my",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "url-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/urls/my",
      "UpstreamHttpMethod": [ "Get" ]
    },
    {
      "DownstreamPathTemplate": "/api/Urls/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "url-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/urls/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ]
    },
    {
      "DownstreamPathTemplate": "/{shortCode}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "url-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/s/{shortCode}",
      "UpstreamHttpMethod": [ "Get" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5130"
  }
}
